  "item": [
    {
      "name": "Create Customer",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Check for successful creation\r",
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "// Capture the ID for the rest of the collection\r",
              "const jsonData = pm.response.json();\r",
              "if (jsonData.id) {\r",
              "    pm.collectionVariables.set(\"customerId\", jsonData.id);\r",
              "}\r",
              "\r",
              "pm.test(\"Response has created_date and updated_date\", function () {\r",
              "    pm.expect(jsonData).to.have.property('created_date');\r",
              "    pm.expect(jsonData).to.have.property('updated_date');\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
